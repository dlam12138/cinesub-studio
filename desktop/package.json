{
  "name": "cinesub-studio-desktop",
  "version": "0.6.2",
  "cinesubBuildFlavor": "unified",
  "private": true,
  "productName": "智译字幕工坊",
  "description": "Electron desktop shell for 智译字幕工坊 / CineSub Studio",
  "main": "main.js",
  "scripts": {
    "start": "node launch.js",
    "pack:win": "electron-builder --win --dir"
  },
  "devDependencies": {
    "electron": "37.10.3",
    "electron-builder": "26.1.0"
  },
  "build": {
    "productName": "智译字幕工坊",
    "appId": "studio.cinesub.app",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "app/backend",
        "filter": [
          "src/**/*",
          "web/**/*",
          "start_app.py",
          "VERSION",
          "README.md",
          "!src/tools/asr_benchmark.py",
          "!src/tools/capture_stage5_baseline.py",
          "!src/tools/code_switch_metrics.py",
          "!src/tools/mixed_language_asr_evidence.py",
          "!src/tools/prepare_*.py",
          "!src/tools/segment_asr_*.py",
          "!src/tools/stage5_go_no_go.py",
          "!src/tools/semantic_review_regression.py",
          "!src/tools/translation_quality_benchmark.py",
          "!src/tools/translation_strategy_finale.py",
          "!src/tools/wenyi_*.py"
        ]
      },
      {
        "from": "../packaging/windows/runtime",
        "to": "app",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../packaging/windows/THIRD_PARTY_NOTICES.md",
        "to": "app/THIRD_PARTY_NOTICES.md"
      }
    ],
    "win": {
      "target": "dir",
      "executableName": "CineSubStudio",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "forceCodeSigning": false
    },
    "publish": null
  }
}
